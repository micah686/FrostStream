{
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning"
    }
  },
  "NATS": {
    "Url": "nats://localhost:4222"
  },
  "Auth": {
    "Audience": "froststream-api",
    "RequireHttpsMetadata": true,
    "ExposeOpenApi": false
  },
  "OpenFga": {
    "Endpoint": "http://localhost:8081",
    "StoreId": "",
    "AuthorizationModelId": ""
  },
  "Cast": {
    "TokenSecret": "(openssl rand -base64 32)",
    "TokenLifetimeMinutes": 240,
    "AdvertisedBaseUrl": "WEB_API_URL",
    "DeviceCacheSeconds": 60,
    "DiscoveryTimeoutSeconds": 5
  },
  "AllowedHosts": "*"
}
