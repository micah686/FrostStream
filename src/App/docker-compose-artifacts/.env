# Deployment-specific values for docker-compose.yaml. Every key here is referenced by the
# compose file; bind-mount paths are absolute paths on the docker host, so re-check them when
# deploying from a different machine (or delete this file and republish to regenerate the keys).
# Values below are the dev defaults from AppHost/aspire-development.env.

# Bind mount source for authentik:/blueprints/froststream.yaml
AUTHENTIK_BINDMOUNT_0=/home/micah/RiderProjects/FrostStream/src/App/AppHost/configs/authentik/blueprints/froststream.yaml

# Parameter authentik-bootstrap-password
AUTHENTIK_BOOTSTRAP_PASSWORD=froststream-dev-admin

# Parameter authentik-bootstrap-token
AUTHENTIK_BOOTSTRAP_TOKEN=froststream-dev-api-token

# Parameter authentik-client-secret
AUTHENTIK_CLIENT_SECRET=froststream-dev-client-secret

# Browser-reachable issuer URL (port must match the authentik host port, 25100)
AUTHENTIK_PUBLIC_AUTHORITY=http://localhost:25100/application/o/froststream/

# Parameter authentik-secret-key
AUTHENTIK_SECRET_KEY=froststream-dev-authentik-secret-key-not-for-production

# Bind mount source for authentik-worker:/blueprints/froststream.yaml
AUTHENTIK_WORKER_BINDMOUNT_0=/home/micah/RiderProjects/FrostStream/src/App/AppHost/configs/authentik/blueprints/froststream.yaml

# LAN-reachable base URL cast devices use to fetch media; empty disables real-device casting
CAST_ADVERTISED_BASE_URL=

# Bind mount source for databridge:/data
DATABRIDGE_BINDMOUNT_0=/home/micah/RiderProjects/FrostStream/data

# Browser-reachable frontend origin, no trailing slash (port must match the frontend host port, 25000)
FRONTEND_PUBLIC_ORIGIN=http://localhost:25000

# Bind mount source for nats:/etc/nats/nats.conf
NATS_BINDMOUNT_0=/home/micah/RiderProjects/FrostStream/src/App/AppHost/configs/nats/nats-server.conf

# Bind mount source for nats:/etc/nats/certs/ws-cert.pem
NATS_BINDMOUNT_1=/home/micah/RiderProjects/FrostStream/src/App/AppHost/configs/nats/certs/ws-cert.pem

# Bind mount source for nats:/etc/nats/certs/ws-key.pem
NATS_BINDMOUNT_2=/home/micah/RiderProjects/FrostStream/src/App/AppHost/configs/nats/certs/ws-key.pem

# Parameter nats-password
NATS_PASSWORD=froststream-dev-nats-password

# Parameter nats-ui-admin-pass
NATS_UI_ADMIN_PASS=admin

# Parameter nats-ui-admin-user
NATS_UI_ADMIN_USER=admin

# Parameter nats-ui-jwt-secret
NATS_UI_JWT_SECRET=froststream-dev-nats-ui-jwt-secret

# Parameter openbao-token
OPENBAO_TOKEN=froststream-dev-root

# Bind mount source for postgres:/etc/postgresql/postgresql.conf
POSTGRES_BINDMOUNT_0=/home/micah/RiderProjects/FrostStream/src/App/AppHost/configs/postgres/postgresql.conf

# Bind mount source for postgres:/wal-archive
POSTGRES_BINDMOUNT_1=/home/micah/RiderProjects/FrostStream/data/wal-archive

# Parameter postgres-password
POSTGRES_PASSWORD=postgres

# Parameter postgres-user
POSTGRES_USER=postgres

# Parameter typesense-api-key
TYPESENSE_API_KEY=froststream-dev-key

# Bind mount source for webapi:/data
WEBAPI_BINDMOUNT_0=/home/micah/RiderProjects/FrostStream/data

# Bind mount source for worker:/data
WORKER_BINDMOUNT_0=/home/micah/RiderProjects/FrostStream/data
