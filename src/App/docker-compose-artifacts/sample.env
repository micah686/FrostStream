# Development compose values. These mirror AppHost/aspire-development.env plus
# bind-mount sources required by the generated docker-compose.yaml.

# Bind mount source for authentik:/blueprints/froststream.yaml
AUTHENTIK_BINDMOUNT_0=/mnt/FrostStream/src/App/AppHost/configs/authentik/blueprints/froststream.yaml

# Parameter authentik-bootstrap-password
AUTHENTIK_BOOTSTRAP_PASSWORD=froststream-dev-admin

# Parameter authentik-bootstrap-token
AUTHENTIK_BOOTSTRAP_TOKEN=froststream-dev-api-token

# Parameter authentik-client-secret
AUTHENTIK_CLIENT_SECRET=froststream-dev-client-secret

# Parameter authentik-secret-key
AUTHENTIK_SECRET_KEY=froststream-dev-authentik-secret-key-not-for-production

# Bind mount source for authentik-worker:/blueprints/froststream.yaml
AUTHENTIK_WORKER_BINDMOUNT_0=/mnt/FrostStream/src/App/AppHost/configs/authentik/blueprints/froststream.yaml

# Container image name for databridge
DATABRIDGE_IMAGE=localhost/froststream-databridge:latest

# Container image name for frontend
FRONTEND_IMAGE=localhost/froststream-frontend:latest

# Bind mount source for nats:/etc/nats/nats.conf
NATS_BINDMOUNT_0=/mnt/FrostStream/src/App/AppHost/configs/nats/nats-server.conf

# Bind mount source for nats:/etc/nats/certs/ws-cert.pem
NATS_BINDMOUNT_1=/mnt/FrostStream/src/App/AppHost/configs/nats/certs/ws-cert.pem

# Bind mount source for nats:/etc/nats/certs/ws-key.pem
NATS_BINDMOUNT_2=/mnt/FrostStream/src/App/AppHost/configs/nats/certs/ws-key.pem

# Parameter nats-password
NATS_PASSWORD=froststream-dev-nats-password

# Bind mount source for postgres:/etc/postgresql/postgresql.conf
POSTGRES_BINDMOUNT_0=/mnt/FrostStream/src/App/AppHost/configs/postgres/postgresql.conf

# Bind mount source for postgres:/wal-archive
POSTGRES_BINDMOUNT_1=/mnt/FrostStream/data/wal-archive

# Parameter postgres-password
POSTGRES_PASSWORD=postgres

# Parameter postgres-user
POSTGRES_USER=postgres

# Shared application storage bind mount source
FROSTSTREAM_STORAGE_BINDMOUNT=/mnt/FrostStream/data

# Host port mappings for local development access
DASHBOARD_HOST_PORT=18888
NATS_HOST_PORT=4222
NATS_MONITOR_HOST_PORT=8222
NATS_WS_HOST_PORT=9222
NATS_UI_HOST_PORT=8088
POSTGRES_HOST_PORT=5432
OPENBAO_HOST_PORT=8200
TYPESENSE_HOST_PORT=8108
AUTHENTIK_HOST_PORT=9000
AUTHENTIK_PUBLIC_AUTHORITY=http://localhost:9000/application/o/froststream/
OPENFGA_HOST_PORT=8081
OPENFGA_STUDIO_HOST_PORT=3000
POT_PROVIDER_HOST_PORT=4416
WEBAPI_HOST_PORT=5041
SCHEDULER_HOST_PORT=5080
FRONTEND_HOST_PORT=8000
FRONTEND_PUBLIC_ORIGIN=http://localhost:8000

# Container image name for scheduler
SCHEDULER_IMAGE=localhost/froststream-scheduler:latest

# Container image name for webapi
WEBAPI_IMAGE=localhost/froststream-webapi:latest

# Container image name for worker
WORKER_IMAGE=localhost/froststream-worker:latest
