# ============================================================================
# AppHost development environment — source of truth for every configurable
# environment variable. Loaded by AppHost.cs at startup; values here override
# variables inherited from the shell.
#
# Do NOT add derived values here (VITE_API_BASE_URL, API_BASE_URL,
# VITE_SINGLE_USER_MODE, VITE_AUTH_MODE, AUTH_AUTHORITY, VITE_AUTH_AUTHORITY,
# AUTH_CLIENT_ID, AUTH_CLIENT_SECRET, OpenBao__*/Typesense__*/Backup__*,
# service endpoints) — AppHost computes those at runtime from the inputs below.
# ============================================================================

# ~~~~~ Mode / hardening ~~~~~
SINGLE_USER_MODE="false"
FROSTSTREAM_PRODUCTION="false"
ENABLE_HTTPS="false"
AUTH_ALLOW_SINGLE_USER_MODE_IN_PRODUCTION="false"
# Defaults to ENABLE_HTTPS; uncomment only to override.
#AUTH_REQUIRE_HTTPS_METADATA="false"
# Defaults to FROSTSTREAM_PRODUCTION (multi-user mode only); uncomment only to override.
#ENABLE_FGA_AUTHENTICATED_ENDPOINTS="false"
# Absolute path to the shared media/storage root; empty = <repo>/data.
FROSTSTREAM_STORAGE_ROOT=""

# ~~~~~ Container image tags ~~~~~

OPENFGA_STUDIO_IMAGE_TAG="latest"



# ~~~~~ Postgres ~~~~~
POSTGRES_USER="postgres"
POSTGRES_PASSWORD="postgres"

# ~~~~~ OpenBao ~~~~~
OPENBAO_TOKEN="froststream-dev-root"

# ~~~~~ TypeSense ~~~~~
TYPESENSE_DATA_DIR="/data"
TYPESENSE_API_KEY="froststream-dev-key"
TYPESENSE_ENABLE_CORS="true"

# ~~~~~ NATS UI (dev tool) ~~~~~
NATS_UI_ADMIN_USER="admin"
NATS_UI_ADMIN_PASS="admin"
JWT_SECRET="froststream-dev-nats-ui-jwt-secret"

# ~~~~~ Authentik (multi-user mode only) ~~~~~
AUTHENTIK_CLIENT_ID="froststream-bff"
AUTHENTIK_CLIENT_SECRET="froststream-dev-client-secret"
# You probably want a GUID or similar, like this: Guid.NewGuid().ToString("N")
AUTHENTIK_SECRET_KEY="froststream-dev-authentik-secret-key-not-for-production"
AUTHENTIK_BOOTSTRAP_EMAIL="admin@localhost"
AUTHENTIK_BOOTSTRAP_PASSWORD="froststream-dev-admin"
AUTHENTIK_BOOTSTRAP_TOKEN="froststream-dev-api-token"
AUTHENTIK_API_AUDIENCE="froststream-api"
# External HTTPS issuer URL; empty = use the local authentik container endpoint.
AUTHENTIK_AUTHORITY=""
# Browser-reachable issuer URL for compose/frontend redirects; empty = AppHost default.
AUTHENTIK_PUBLIC_AUTHORITY="http://localhost:9000/application/o/froststream/"
# Optional named signing key; empty = authentik default.
AUTHENTIK_SIGNING_KEY_NAME=""

# ~~~~~ Auth (BFF / frontend) ~~~~~
AUTH_SCOPES="openid profile email groups offline_access"
AUTH_EXPOSE_OPENAPI="false"
FRONTEND_PUBLIC_ORIGIN="http://localhost:8000"

# ~~~~~ OpenFGA (multi-user mode only) ~~~~~
OPENFGA_API_TOKEN="froststream-dev-openfga-token-change-me"
OPENFGA_AUTO_PROVISION="true"
# Both required when OPENFGA_AUTO_PROVISION="false".
OPENFGA_STORE_ID=""
OPENFGA_AUTHORIZATION_MODEL_ID=""
# OIDC subjects granted owner on first provision.
OPENFGA_BOOTSTRAP_OWNER_SUB=""

# ~~~~~ Casting ~~~~~
# LAN-reachable base URL cast devices use to fetch media (required for real-device
# casting under Aspire, whose proxied endpoints bind to localhost).
CAST_ADVERTISED_BASE_URL=""
