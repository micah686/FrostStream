# Copy to .env for standalone `pnpm dev`. AppHost/Aspire injects these automatically.
SINGLE_USER_MODE=true
#SINGLE_USER_NAME=

# Multi-user via Authentik (set SINGLE_USER_MODE=false first):
#AUTH_AUTHORITY=http://localhost:9000/application/o/froststream/
#AUTH_CLIENT_ID=froststream-bff
#AUTH_CLIENT_SECRET=froststream-dev-client-secret
#AUTH_SCOPES=openid profile email groups
#API_BASE_URL=https://localhost:7035
